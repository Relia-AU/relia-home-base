# Copy to .env.local for development. Never commit real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Access (production only; local dev bypasses)
CF_ACCESS_AUD=
CF_ACCESS_TEAM_DOMAIN=
LOCAL_DEV=1

# Linear
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_WEBHOOK_SECRET=

# Slack incoming webhooks (one per channel)
SLACK_WEBHOOK_DEPLOYS=
SLACK_WEBHOOK_ONCALL=
SLACK_WEBHOOK_SECURITY=
SLACK_WEBHOOK_ENG=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# GitHub (for code review agent)
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
